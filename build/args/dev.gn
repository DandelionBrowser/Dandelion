# Fast-iteration configuration for local Dandelion development.
#
# Tuned for incremental edit-build-run cycles on developer hardware rather than
# for the performance of the resulting binary. Use `release.gn` for anything you
# intend to benchmark or ship.
#
# Create build/args/local.gn to override any of these without touching the
# committed defaults; build.py appends it automatically and git ignores it.

target_cpu = "x64"

# A release-mode build with DCHECKs kept on. Full debug builds link slowly and
# produce enormous binaries; DCHECKs retain the assertion coverage that actually
# catches Chromium integration mistakes.
is_debug = false
dcheck_always_on = true

# Links Chromium as many small shared libraries, so a one-file edit relinks in
# seconds instead of minutes. Incompatible with is_official_build.
is_component_build = true

# Symbols are the single largest contributor to build time and disk use.
# Level 1 keeps file and line information for stack traces without the full
# debug type information that level 2 emits.
symbol_level = 1
blink_symbol_level = 0
v8_symbol_level = 0

# Native Client is deprecated and irrelevant to Dandelion, and removing it cuts
# a substantial amount of work from a clean build.
enable_nacl = false

# Profile-guided optimisation only pays off for official builds and requires
# downloaded profile data.
chrome_pgo_phase = 0

# Google's distributed build backend is not available outside Google.
use_remoteexec = false
