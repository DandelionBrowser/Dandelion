# Dandelion is an overlay repository: the Chromium checkout lives outside it and
# is never committed here. See docs/ARCHITECTURE.md.

# Python bytecode from build/ tooling.
__pycache__/
*.py[cod]

# Local developer overrides for build configuration (build/args/*.gn are the
# committed defaults; out/<config>/args.gn is generated by `gn gen`).
build/args/local.gn

# Build and sync logs.
*.log

# Editor and OS noise.
.vscode/
.idea/
*.swp
Thumbs.db
.DS_Store
