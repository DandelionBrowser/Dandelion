## Dandelion Brand
##
## Dandelion must be treated as a brand. It cannot be:
## - Transliterated.
## - Translated.
##
## Declension should be avoided where possible, leaving the original
## brand unaltered in prominent UI positions.

-brand-shorter-name = Dandelion
-brand-short-name = Dandelion
-brand-shortcut-name = Dandelion
-brand-full-name = Dandelion
# This brand name can be used in messages where the product name needs to
# remain unchanged across different release channels.
-brand-product-name = Dandelion
-vendor-short-name = Dandelion
trademarkInfo = { " " }
